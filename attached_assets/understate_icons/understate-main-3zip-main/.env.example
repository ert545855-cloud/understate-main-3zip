# ═══════════════════════════════════════════════════════════════
# UNDERSTATE — Ortam Değişkenleri Şablonu
# ───────────────────────────────────────────────────────────────
# KURULUM:
#   cp .env.example .env
#   Aşağıdaki <PLACEHOLDER> değerlerini gerçek değerlerle doldurun.
#   .env dosyasını ASLA Git'e commit etmeyin (.gitignore'da hariç tutulmuş).
# ═══════════════════════════════════════════════════════════════

NODE_ENV=production
PORT=5000

# ── Veritabanı ────────────────────────────────────────────────
# PostgreSQL bağlantı URL'si (zorunlu — tanımsızsa sunucu başlamaz)
DATABASE_URL=postgresql://<KULLANICI>:<ŞİFRE>@<HOST>:<PORT>/<VT_ADI>

# ── JWT Kimlik Doğrulama ──────────────────────────────────────
# En az 32 karakter, rastgele oluşturulmuş güçlü bir string (zorunlu)
# Üretmek için: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=<EN_AZ_32_KARAKTER_RASTGELE_STRING>

# ── Sunucu URL ────────────────────────────────────────────────
# Üretim ortamındaki tam URL (ör: https://understate.onrender.com)
PUBLIC_URL=https://<ALAN_ADINIZ>

# ── CORS ─────────────────────────────────────────────────────
# İzin verilen kaynaklar, virgülle ayrılmış (güvenlik için * kullanmayın)
ALLOWED_ORIGINS=https://<ALAN_ADINIZ>,capacitor://localhost

# ── Yönetici Kullanıcıları ───────────────────────────────────
ADMIN_USERS=admin

# ── E-posta (opsiyonel) ──────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=<EMAIL_KULLANICI_ADI>
SMTP_PASS=<EMAIL_SIFRE>
SMTP_FROM=noreply@understate.game

# ── Web Push Bildirimleri (opsiyonel) ────────────────────────
# Üretmek için: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=<VAPID_PUBLIC_KEY>
VAPID_PRIVATE_KEY=<VAPID_PRIVATE_KEY>

# ── Giphy API (opsiyonel) ────────────────────────────────────
GIPHY_API_KEY=<GIPHY_API_KEY>

# ── Brevo (opsiyonel, doğrulama maili göndermek için) ────────
BREVO_API_KEY=<BREVO_API_KEY>

# ── Beta Mod (opsiyonel) ──────────────────────────────────────
BETA_MODE=false
BETA_INVITE_CODES=<VIRGULLE_AYRILMIS_DAVET_KODLARI>

# ── AWS S3 (opsiyonel, medya yükleme için) ───────────────────
AWS_ACCESS_KEY_ID=<AWS_ACCESS_KEY_ID>
AWS_SECRET_ACCESS_KEY=<AWS_SECRET_ACCESS_KEY>
AWS_REGION=eu-central-1
AWS_S3_BUCKET=<S3_BUCKET_ADI>
